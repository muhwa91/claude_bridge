# claude_bridge 환경설정 예시 — 이 파일을 .env 로 복사해 값을 채우세요.
# .env 는 절대 커밋하지 않습니다(.gitignore 에 포함됨). 디스코드 전용.

# 봇 토큰 (Developer Portal > Bot > Reset Token). 코드·로그·커밋에 평문 금지.
DISCORD_BOT_TOKEN=

# 허용 유저 ID 목록(콤마 구분). 본인 유저 ID만 — 목록 밖 유저는 무시됩니다.
# 확인: 디스코드 개발자 모드 켜고 본인 이름 우클릭 > 사용자 ID 복사.
DISCORD_ALLOWED_USER_IDS=

# claude 작업 1건의 최대 실행 시간(초). 초과 시 프로세스 트리를 강제 종료합니다.
CLAUDE_TIMEOUT_SEC=900

# 원격 지시 대상 프로젝트 루트(모노레포 루트 기준 상대경로). 이 폴더 직속만 대상.
TARGET_ROOT=Hachiware/_Project
