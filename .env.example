# telegram_bridge 환경설정 예시 — 이 파일을 .env 로 복사해 값을 채우세요.
# .env 는 절대 커밋하지 않습니다(.gitignore 에 포함됨).

# 텔레그램 봇 토큰 (@BotFather 에서 /newbot 으로 발급). 코드·로그·커밋에 평문 금지.
TG_BOT_TOKEN=

# 허용 chat ID 목록(콤마 구분). 본인 chat ID만 넣으세요 — 목록 밖 메시지는 무시됩니다.
# 자신의 chat ID 확인: 봇에게 아무 메시지나 보낸 뒤
#   https://api.telegram.org/bot<토큰>/getUpdates 의 message.chat.id 값.
TG_ALLOWED_CHAT_IDS=

# claude 작업 1건의 최대 실행 시간(초). 초과 시 프로세스 트리를 강제 종료합니다.
CLAUDE_TIMEOUT_SEC=900

# 원격 지시 대상 프로젝트 루트(모노레포 루트 기준 상대경로). 이 폴더 직속만 대상.
TARGET_ROOT=Hachiware/_Project
