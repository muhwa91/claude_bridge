# claude_bridge 환경설정 예시 — 이 파일을 .env 로 복사해 값을 채우세요.
# .env 는 절대 커밋하지 않습니다(.gitignore 에 포함됨).
# 디스코드 이관 중: 텔레그램·디스코드 변수 공존(어댑터가 활성 플랫폼 선택). 안정화 후 텔레그램 제거.
# 플랫폼 선택: DISCORD_BOT_TOKEN 이 채워져 있으면 디스코드로 구동, 비어 있으면 텔레그램.
# 강제 지정하려면 BRIDGE_PLATFORM=discord | telegram (디스코드 토큰이 있어도 telegram 강제 가능).
BRIDGE_PLATFORM=

# --- 디스코드 (이관 대상) ---
# 봇 토큰 (Developer Portal > Bot > Reset Token). 코드·로그·커밋에 평문 금지.
DISCORD_BOT_TOKEN=

# 허용 유저 ID 목록(콤마 구분). 본인 유저 ID만 — 목록 밖 유저는 무시됩니다.
# 확인: 디스코드 개발자 모드 켜고 본인 이름 우클릭 > 사용자 ID 복사.
DISCORD_ALLOWED_USER_IDS=

# --- 텔레그램 (제거 예정, 병행 유지) ---
# 텔레그램 봇 토큰 (@BotFather 에서 /newbot 으로 발급). 코드·로그·커밋에 평문 금지.
TG_BOT_TOKEN=

# 허용 chat ID 목록(콤마 구분). 본인 chat ID만 넣으세요 — 목록 밖 메시지는 무시됩니다.
# 자신의 chat ID 확인: 봇에게 아무 메시지나 보낸 뒤
#   https://api.telegram.org/bot<토큰>/getUpdates 의 message.chat.id 값.
TG_ALLOWED_CHAT_IDS=

# claude 작업 1건의 최대 실행 시간(초). 초과 시 프로세스 트리를 강제 종료합니다.
CLAUDE_TIMEOUT_SEC=900

# 원격 지시 대상 프로젝트 루트(모노레포 루트 기준 상대경로). 이 폴더 직속만 대상.
TARGET_ROOT=Hachiware/_Project
